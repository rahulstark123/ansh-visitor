datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/client"
}

// ─────────────────────────────────────────────────────────────
// Workspace — top-level tenant container
// ─────────────────────────────────────────────────────────────
model Workspace {
  id                Int                      @id @default(autoincrement())
  name              String?
  plan              String                   @default("free") // "free" | "pro"
  createdAt         DateTime                 @default(now())
  profiles          Profile[]
  visitors          Visitor[]
  config            WorkspaceConfig?
  subscriptions     Subscription[]
  transactions      Transaction[]
  registrationLinks PublicRegistrationLink[]
}

// ─────────────────────────────────────────────────────────────
// WorkspaceConfig — persists dropdown option lists as PG arrays
// One record per workspace (unique wid)
// ─────────────────────────────────────────────────────────────
model WorkspaceConfig {
  id             Int       @id @default(autoincrement())
  wid            Int       @unique
  workspace      Workspace @relation(fields: [wid], references: [id], onDelete: Cascade)
  departments    String[]  @default(["Engineering", "HR & Operations", "Product Management", "Enterprise Sales"])
  designations   String[]  @default(["Software Engineer", "Senior Developer", "Product Manager", "HR Manager", "Operations Admin", "Sales Director"])
  officeBranches String[]  @default(["HQ - Bangalore", "Delhi Branch", "Mumbai Office"])
  workLocations  String[]  @default(["Remote", "On-site", "Hybrid"])
  updatedAt      DateTime  @updatedAt
}

// ─────────────────────────────────────────────────────────────
// Profile — team member / host (maps to Supabase Auth user id)
// ─────────────────────────────────────────────────────────────
model Profile {
  id                String                   @id // Supabase Auth UUID
  name              String
  email             String                   @unique
  role              String                   @default("Employee") // "Admin" | "Manager" | "Employee"
  department        String                   @default("General")
  designation       String?
  officeBranch      String?
  workLocation      String?
  avatarInitials    String                   @default("EE")
  status            String                   @default("Active") // "Active" | "Inactive"
  phoneNumber       String?
  personalEmail     String?
  bloodGroup        String?
  dob               String?
  code              String?
  joiningDate       String?
  reportingManager  String?
  reportingHR       String?
  emergencyName     String?
  emergencyPhone    String?
  acceptedTerms     Boolean                  @default(false)
  acceptedPrivacy   Boolean                  @default(false)
  consentAt         DateTime?
  termsVersion      String?
  privacyVersion    String?
  createdAt         DateTime                 @default(now())
  wid               Int?
  workspace         Workspace?               @relation(fields: [wid], references: [id], onDelete: Cascade)
  visitors          Visitor[]                @relation("HostRelation")
  registrationLinks PublicRegistrationLink[]

  @@index([wid]) // fast workspace scoped queries
  @@index([email]) // fast lookup by email
}

// ─────────────────────────────────────────────────────────────
// Visitor — individual visit log entry
// ─────────────────────────────────────────────────────────────
model Visitor {
  id              String    @id @default(cuid())
  name            String
  email           String
  phone           String
  company         String?
  purpose         String // "Interview" | "Meeting" | "Delivery" | "Vendor" | "Other"
  status          String    @default("Expected") // "Expected" | "CheckedIn" | "CheckedOut"
  hostId          String
  host            Profile   @relation("HostRelation", fields: [hostId], references: [id], onDelete: Cascade)
  hostName        String
  checkedInAt     DateTime?
  checkedOutAt    DateTime?
  preRegisteredAt DateTime  @default(now())
  idProofType     String?
  idProofNumber   String?
  badgeNumber     String?
  qrCode          String?
  qrValidUntil    DateTime?
  walkIn          Boolean   @default(false)
  notes           String?
  wid             Int
  workspace       Workspace @relation(fields: [wid], references: [id], onDelete: Cascade)

  @@index([wid]) // workspace list queries
  @@index([hostId]) // host-scoped visitor lists
  @@index([status]) // filter by status
  @@index([wid, status]) // compound: workspace + status filter (most common query)
  @@index([preRegisteredAt]) // date-sorted lists
}

// ─────────────────────────────────────────────────────────────
// Subscription — workspace Pro plan subscription records
// ─────────────────────────────────────────────────────────────
model Subscription {
  id                 String        @id @default(cuid())
  wid                Int
  workspace          Workspace     @relation(fields: [wid], references: [id], onDelete: Cascade)
  plan               String        @default("pro") // "pro"
  status             String        @default("pending") // "pending" | "active" | "cancelled" | "expired" | "failed"
  amount             Int // minor units (paisa / cents)
  currency           String
  region             String // "IN" | "INTL"
  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?
  cancelledAt        DateTime?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  transactions       Transaction[]

  @@index([wid])
  @@index([wid, status])
  @@index([status])
}

// ─────────────────────────────────────────────────────────────
// Transaction — individual payment attempts (success / failed)
// ─────────────────────────────────────────────────────────────
model Transaction {
  id                String       @id @default(cuid())
  wid               Int
  workspace         Workspace    @relation(fields: [wid], references: [id], onDelete: Cascade)
  subscriptionId    String
  subscription      Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  razorpayOrderId   String       @unique
  razorpayPaymentId String?      @unique
  amount            Int
  currency          String
  region            String
  status            String       @default("pending") // "pending" | "success" | "failed" | "cancelled"
  failureReason     String?
  createdAt         DateTime     @default(now())
  verifiedAt        DateTime?

  @@index([wid])
  @@index([subscriptionId])
  @@index([status])
  @@index([wid, status])
}

// ─────────────────────────────────────────────────────────────
// PublicRegistrationLink — customizable public pre-register page
// ─────────────────────────────────────────────────────────────
model PublicRegistrationLink {
  id                   String    @id @default(cuid())
  slug                 String    @unique
  wid                  Int
  workspace            Workspace @relation(fields: [wid], references: [id], onDelete: Cascade)
  hostId               String
  host                 Profile   @relation(fields: [hostId], references: [id], onDelete: Cascade)
  officeBranch         String
  enabled              Boolean   @default(true)
  designTheme          String    @default("classic") // classic | modern | minimal | bold | glass
  pageTitle            String?
  welcomeMessage       String?
  qrValidityPeriod     String    @default("24h")
  fieldNameRequired    Boolean   @default(true)
  fieldPhoneRequired   Boolean   @default(false)
  fieldEmailRequired   Boolean   @default(false)
  fieldPurposeRequired Boolean   @default(false)
  fieldIdProofRequired Boolean   @default(false)
  fieldCompanyEnabled  Boolean   @default(true)
  fieldCompanyRequired Boolean   @default(false)
  fieldNotesEnabled    Boolean   @default(true)
  fieldNotesRequired   Boolean   @default(false)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  @@unique([wid, hostId])
  @@index([wid])
  @@index([hostId])
}
